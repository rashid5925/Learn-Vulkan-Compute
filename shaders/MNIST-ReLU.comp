#version 450

layout(local_size_x = 16, local_size_y = 1, local_size_z = 1) in;

layout(constant_id = 0) const uint LO1r = 10;
layout(constant_id = 1) const uint LO1c = 10;

layout(binding = 0) buffer InputA {
    float a[LO1r*LO1c];
};

void main() {
    uint i = gl_GlobalInvocationID.x; 
    
    if (i >= LO1r * LO1c) {
        return;
    }
    
    a[i] = max(0.0f, a[i]);
}
